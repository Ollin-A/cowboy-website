# Shopify Hydrogen environment variables
# Copy this file to .env and fill in your values.

# Required: Session secret for cookie signing (any random string)
SESSION_SECRET="your-session-secret-here"

# Required: Your Shopify store domain (without https://)
PUBLIC_STORE_DOMAIN="your-store.myshopify.com"

# Required: Storefront API public access token
# Generate at: Shopify Admin → Settings → Apps and sales channels → Develop apps → Storefront API
PUBLIC_STOREFRONT_API_TOKEN="your-storefront-api-token"

# Optional: Storefront ID (used by Hydrogen analytics)
PUBLIC_STOREFRONT_ID=""

# Optional: Checkout domain (defaults to store domain)
PUBLIC_CHECKOUT_DOMAIN="your-store.myshopify.com"
